#14=IFCMATERIALLAYER($,240.,$);
#15=IFCMATERIALLAYERSET((#14),'Standard');
#16=IFCMATERIALLAYERSETUSAGE(#15,.AXIS2.,.POSITIVE.,0.);
#17=IFCRELASSOCIATESMATERIAL('0000000000000000000005',$,$,$,(#13),#16);
#18=IFCRELCONTAINEDINSPATIALSTRUCTURE('0000000000000000000006',$,$,$,(#13),#5);
#19=IFCCARTESIANPOINT((0.,0.,0.));
