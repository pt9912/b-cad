#22=IFCSHAPEREPRESENTATION($,'Axis','Curve2D',(#21));
#23=IFCEXTRUDEDAREASOLID($,$,$,2500.);
#24=IFCSHAPEREPRESENTATION($,'Body','SweptSolid',(#23));
