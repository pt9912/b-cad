#26=IFCWALL('0000000000000000000007',$,'Wall',$,$,$,#25,$,$);
#27=IFCMATERIALLAYER($,300.,$);
#28=IFCMATERIALLAYERSET((#27),'Standard');
#29=IFCMATERIALLAYERSETUSAGE(#28,.AXIS2.,.POSITIVE.,0.);
